# ============================================
# 外部 MongoDB 配置（使用已存在的 MongoDB 实例）
# ============================================

# MongoDB 连接配置
# 注意：使用已存在的 mongodb 容器
MONGO_ROOT_USERNAME=admin
MONGO_ROOT_PASSWORD=your_mongodb_password_here

# Backend 连接 URI 配置
# 选项 1: 通过 Docker 网络（推荐 - 如果两个容器在同一网络）
# MONGODB_URI=mongodb://admin:your_password@mongodb:27017/words-learning?authSource=admin

# 选项 2: 通过 host.docker.internal（如果不在同一网络）
MONGODB_URI=mongodb://admin:your_password@host.docker.internal:27017/words-learning?authSource=admin

# 选项 3: 通过 localhost（如果 backend 不在容器中运行）
# MONGODB_URI=mongodb://admin:your_password@localhost:27017/words-learning?authSource=admin

# Backend Configuration
JWT_SECRET=your_jwt_secret_here_at_least_32_characters
PORT=8088

# AI API Configuration (Optional)
OPENAI_API_KEY=
DEEPSEEK_API_KEY=
USE_DEEPSEEK=true

# OCR Configuration (Optional)
GOOGLE_VISION_API_KEY=
BAIDU_OCR_API_KEY=
BAIDU_OCR_SECRET_KEY=
USE_GOOGLE_VISION=true
