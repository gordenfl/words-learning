#!/bin/bash
# 一键部署到服务器脚本

echo "🚀 Deploying to gordenfl.com..."

# 服务器信息（请根据实际情况修改）
SERVER_USER="your-username"  # ubuntu, ec2-user, admin 等
SERVER_HOST="your-server.com"  # 你的服务器域名或 IP
SSH_KEY="$HOME/.ssh/your-key.pem"  # 你的 SSH 密钥路径
DEPLOY_PATH="/home/$SERVER_USER/words-learning"  # 服务器上的部署路径

echo ""
echo "📦 准备部署包..."

# 创建部署包（排除不需要的文件）
tar czf words-learning-deploy.tar.gz \
  --exclude='node_modules' \
  --exclude='.git' \
  --exclude='.env' \
  --exclude='*.log' \
  --exclude='.DS_Store' \
  backend/ docker-compose.yml .env.example

echo "✅ 部署包创建完成"

echo ""
echo "📤 上传到服务器..."

# 上传部署包
scp -i "$SSH_KEY" words-learning-deploy.tar.gz "$SERVER_USER@$SERVER_HOST:~/"

echo "✅ 上传完成"

echo ""
echo "🔧 在服务器上部署..."

# SSH 到服务器执行部署命令
ssh -i "$SSH_KEY" "$SERVER_USER@$SERVER_HOST" << 'ENDSSH'
  echo "📂 创建部署目录..."
  mkdir -p ~/words-learning
  cd ~/words-learning
  
  echo "📦 解压部署包..."
  tar xzf ../words-learning-deploy.tar.gz
  
  echo "⚙️  配置环境变量..."
  if [ ! -f .env ]; then
    cp .env.example .env
    echo "⚠️  请编辑 .env 文件填入配置！"
    echo "   nano ~/words-learning/.env"
  else
    echo "✅ .env 文件已存在"
  fi
  
  echo "🐳 启动 Docker 服务..."
  docker-compose down 2>/dev/null
  docker-compose up -d --build
  
  echo ""
  echo "✅ 部署完成！"
  echo ""
  echo "查看日志: docker-compose logs -f backend"
  echo "查看状态: docker-compose ps"
  echo ""
  
  # 显示容器状态
  sleep 3
  docker-compose ps
  
  # 显示最近日志
  echo ""
  echo "📋 最近日志:"
  docker-compose logs --tail 10 backend
ENDSSH

echo ""
echo "🎉 部署脚本执行完成！"
echo ""
echo "🌐 你的 API 地址: http://gordenfl.com:8088"
echo "📱 更新手机 App 的 config.js:"
echo "   HOST: 'gordenfl.com'"
echo "   PORT: '8088'"
echo ""
echo "🔍 连接到服务器查看状态:"
echo "   ssh -i $SSH_KEY $SERVER_USER@$SERVER_HOST"
echo "   cd ~/words-learning"
echo "   docker-compose logs -f backend"

