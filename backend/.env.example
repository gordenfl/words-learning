# MongoDB配置
MONGO_ROOT_USERNAME={username_for_mongodb}
MONGO_ROOT_PASSWORD={password_for_mongodb}
MONGO_DATABASE={database_name}
MONGODB_URI=mongodb://{username_for_mongodb}:{password_for_mongodb}@mongodb:27017/{database_name}?authSource=admin
# JWT密钥
JWT_SECRET={your-super-secret-jwt-key-change-this-in-production}

# ==================== OCR配置 ====================
# 选择使用哪个OCR服务（两选一）

# 方案1：百度OCR（推荐 - 有免费配额）
# 1. 访问 https://console.bce.baidu.com/ai/\#/ai/ocr/overview/index
# 2. 创建应用获取 API Key 和 Secret Key
# 3. 每天有免费的调用次数
USE_GOOGLE_VISION=false
BAIDU_OCR_API_KEY={your_baidu_api_key_here}
BAIDU_OCR_SECRET_KEY={your_baidu_secret_key_here}

# 方案2：Google Cloud Vision（需要启用billing）
# USE_GOOGLE_VISION=true
# GOOGLE_VISION_API_KEY=your_google_api_key_here

# ==================== AI服务配置 ====================
# 用于生成自然的中文故事

# 使用DeepSeek（推荐 - 便宜）
USE_DEEPSEEK=true
DEEPSEEK_API_KEY={your_deepseek_api_key_here}

# 或使用OpenAI
# OPENAI_API_KEY={your_openai_api_key_here}
