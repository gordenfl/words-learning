# MongoDB（与 Node 版共用）
# 本地连服务器 MongoDB：先用 SSH 隧道，再连 localhost:27017（见下方说明）
MONGODB_URI=mongodb://localhost:27017/words-learning

# 若 MongoDB 开启了认证（与 photoshare 一致）：
# MONGODB_URI=mongodb://admin:你的密码@localhost:27017/words-learning?authSource=admin

# JWT（与 Node 版一致）。不要留空：空字符串会让 Django SECRET_KEY 为空，所有请求返回 500。
JWT_SECRET=your_jwt_secret_here_at_least_32_characters

# AI / OCR / 语音（可选，与 Node 版一致）
# OPENAI_API_KEY=
# DEEPSEEK_API_KEY=
# USE_DEEPSEEK=true
# GOOGLE_VISION_API_KEY=
# BAIDU_OCR_*=
# USE_GOOGLE_VISION=
# GOOGLE_SPEECH_API_KEY=
# USE_BAIDU_SPEECH=
# APPLE_BUNDLE_ID
#
# TTS 朗读（可选，无需配置环境变量）:
#   pip install ChatTTS torch torchaudio numpy
#   安装后朗读使用 AI 语音，否则回退到浏览器内置语音
#   首次运行会下载模型（约 500MB）
