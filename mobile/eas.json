{
    "cli": {
        "version": ">= 5.9.1"
    },
    "build": {
        "development": {
            "developmentClient": true,
            "distribution": "internal",
            "node": "20.18.1",
            "ios": {
                "simulator": true,
                "image": "stable"
            },
            "env": {
                "EXPO_USE_NPM": "1",
                "NPM_CONFIG_PACKAGE_MANAGER": "npm"
            }
        },
        "preview": {
            "distribution": "internal",
            "node": "20.18.1",
            "android": {
                "buildType": "apk"
            },
            "ios": {
                "simulator": true,
                "image": "sdk-54"
            },
            "env": {
                "EXPO_USE_NPM": "1",
                "NPM_CONFIG_PACKAGE_MANAGER": "npm"
            }
        },
        "production": {
            "node": "20.18.1",
            "android": {
                "buildType": "apk"
            },
            "ios": {
                "buildConfiguration": "Release",
                "image": "sdk-54"
            },
            "env": {
                "EXPO_USE_NPM": "1",
                "NPM_CONFIG_PACKAGE_MANAGER": "npm"
            },
            "cache": {
                "disabled": false
            }
        }
    },
    "submit": {
        "production": {}
    }
}