{
  "name": "mobile",
  "private": true,
  "version": "1.0.1",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "pinyin:audio:manifest": "node scripts/generate-pinyin-audio-manifest.mjs",
    "pinyin:audio:download": "node scripts/download-pinyin-audio.mjs",
    "pinyin:sync-hanyu": "node scripts/sync-hanyu-pinyin-audio.mjs",
    "build": "vite build && node scripts/strip-crossorigin.cjs",
    "preview": "vite preview",
    "cap:init": "cap add ios && cap add android",
    "cap:sync": "npm run build && npx cap sync && node scripts/ensure-webdist.cjs",
    "cap:ios": "npm run build && npx cap sync ios && node scripts/ensure-webdist.cjs && npx cap open ios",
    "cap:android": "npm run build && npx cap sync android && npx cap open android"
  },
  "dependencies": {
    "@capacitor-community/apple-sign-in": "^7.1.0",
    "@capacitor/android": "^7.6.0",
    "@capacitor/cli": "^7.6.0",
    "@capacitor/core": "^7.6.0",
    "@capacitor/ios": "^7.6.0",
    "axios": "^1.13.6",
    "pinia": "^3.0.4",
    "vue": "^3.5.30",
    "vue-router": "^4.6.4"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@vitejs/plugin-vue": "^5.2.1",
    "typescript": "^5.9.3",
    "vite": "^5.4.0"
  }
}
