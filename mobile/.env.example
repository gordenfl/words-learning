# 仅开发环境生效：npm run dev / 非 production 的 vite 构建。
# 打 IPA 时 vite build 为 production，会忽略此处变量，固定连 config.js 里的外服 API。
# 复制为 .env 后生效：cp .env.example .env
VITE_API_HOST=127.0.0.1
VITE_API_PORT=8001

# Pinyin static audio (after: npm run pinyin:sync-hanyu)
# VITE_PINYIN_AUDIO_BASE_URL=/audio/pinyin-hanyu
# VITE_PINYIN_AUDIO_NAMING=hanyu
